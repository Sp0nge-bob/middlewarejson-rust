# --- Upstream: 3x-ui JSON subscription (sub-сервер, НЕ panel API) ---
# Не путать с PANEL_*: подписки на отдельном порту, без web base path.
# Скопируйте JSON URL из карточки клиента в панели и разбейте на BASE + PATH.
# Пример: https://example.com/<ваш-json-path>/<sub_id>
#   UPSTREAM_BASE_URL=https://example.com
#   UPSTREAM_JSON_PATH=/<ваш-json-path>
UPSTREAM_BASE_URL=https://upstream.example.com
UPSTREAM_JSON_PATH=/json
UPSTREAM_VERIFY_SSL=true
UPSTREAM_HOST_HEADER=

REQUEST_TIMEOUT_SEC=15

# --- Agent ---
AGENT_HOST=127.0.0.1
AGENT_PORT=8080
# Путь, на котором слушает агент (nginx proxy_pass). Пусто = как UPSTREAM_JSON_PATH.
AGENT_JSON_PATH=

# --- Transform: passthrough | rules (rules required for balancers) ---
TRANSFORM_MODE=rules
DB_PATH=data/middleware.db

# --- 3x-ui Panel API (inbound catalog + client groups) ---
PANEL_API_BASE_URL=
PANEL_WEB_BASE_PATH=
PANEL_API_TOKEN=
PANEL_VERIFY_SSL=

# --- Panel sync (catalog + client groups) ---
PANEL_SYNC_ON_STARTUP=true
PANEL_SYNC_INTERVAL=24h